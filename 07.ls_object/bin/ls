#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require 'pathname'
require_relative '../lib/command'

opt = OptionParser.new
params = {}

opt.on('-a') { |v| params[:all] = v }
opt.on('-r') { |v| params[:reverse] = v }

opt.parse!(ARGV)
path = ARGV[0] || '.'
pathname = Pathname(path)

puts Command.new(params, pathname).output
